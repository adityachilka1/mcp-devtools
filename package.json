{
  "name": "mcp-devtools",
  "version": "0.1.0",
  "description": "Chrome DevTools for the Model Context Protocol. Inspect, profile, replay, and diff every MCP call your agent makes.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "devtools",
    "inspector",
    "profiler",
    "llm",
    "agents",
    "anthropic",
    "claude",
    "observability"
  ],
  "license": "MIT",
  "author": "Aditya Chilka <https://github.com/adityachilka1>",
  "homepage": "https://github.com/adityachilka1/mcp-devtools#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adityachilka1/mcp-devtools.git"
  },
  "bugs": "https://github.com/adityachilka1/mcp-devtools/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mcp-devtools": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./embed": {
      "types": "./dist/embed.d.ts",
      "import": "./dist/embed.js"
    }
  },
  "files": [
    "dist",
    "ui",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "cac": "^6.7.14",
    "fastify": "^5.0.0",
    "kleur": "^4.1.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
