# https://editorconfig.org — shared editor settings across the team.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{md,markdown}]
trim_trailing_whitespace = false   # markdown uses trailing two-spaces for line breaks

[Makefile]
indent_style = tab
